{
  "extends": "astro/tsconfigs/strict",
  "types": ["unplugin-icons/types/astro"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@assets/*": ["src/assets/*"],
      "@layouts/*": ["src/layouts/*"],
      "@lib/*": ["src/lib/*"],
      "@consts": ["src/consts.ts"],
      "@types": ["src/types.ts"],
      "@content": ["src/content/*"]
    }
  }
}
